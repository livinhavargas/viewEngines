<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Lista de Produtos - EJS</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; }
        .tabela-produtos { width: 100%; border-collapse: collapse; max-width: 600px; }
        .tabela-produtos th, .tabela-produtos td { border: 1px solid #ddd; padding: 10px; text-align: left; }
        .tabela-produtos th { background-color: #4CAF50; color: white; }
        .tabela-produtos tr:nth-child(even) { background-color: #f9f9f9; }
    </style>
</head>
<body>

    <h1>Lista de Produtos (EJS)</h1>

    <% if (produtos.length > 0) { %>
        <table class="tabela-produtos">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Preço</th>
                </tr>
            </thead>
            <tbody>
                <% produtos.forEach(function(produto) { %>
                    <tr>
                        <td><%= produto.id %></td>
                        <td><%= produto.nome %></td>
                        <td>R$ <%= produto.preco.toFixed(2).replace('.', ',') %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <p>Nenhum produto cadastrado.</p>
    <% } %>

</body>
</html>