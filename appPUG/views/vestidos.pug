extends layout

block content
  style.
    body {
      font-family: Arial, sans-serif;
      background: #ffe6f0;
      margin: 0;
      padding: 20px;
      text-align: center;
    }

    h1 {
      color: #d6336c;
    }

    h2 {
      color: #f77f00;
    }

    p {
      color: #6f1d1b;
      font-size: 16px;
    }

    img {
      width: 300px;
      height: auto;
      margin: 20px 0;
      border-radius: 8px;
    }

  h1= title
  h2> Coleção de Vestidos
  p Welcome to #{title}
  
  img(src='/images/vestidos.jpg', alt='Vestidos')
  p Os vestidos da nossa coleção são elegantes e perfeitos para qualquer ocasião!